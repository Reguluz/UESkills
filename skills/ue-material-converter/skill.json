{
  "title": "UE材质转换器",
  "description": "用于Unreal Engine材质开发的转换工具，支持蓝图转HLSL函数、Shadertoy/GLSL/HLSL转Custom节点",
  "author": "UE Lite Skill",
  "version": "1.0.0",
  "icon": "🎨",
  "tags": ["ue", "unreal", "material", "shader", "hlsl", "glsl", "shadertoy", "blueprint"],
  "triggers": [
    "蓝图转HLSL",
    "材质节点转换",
    "Shadertoy转UE",
    "GLSL转Custom节点",
    "HLSL转Custom节点",
    "UE材质函数"
  ],
  "variables": {
    "ueVersion": {
      "type": "string",
      "default": "5.3",
      "description": "目标UE版本"
    },
    "outputFormat": {
      "type": "select",
      "options": ["function", "struct", "materialFunction"],
      "default": "function",
      "description": "输出格式"
    }
  }
}
