{
  "version": "5.3",
  "preferences": {
    "coordinateSystem": "ue_default",
    "textureSampling": "auto",
    "commentStyle": "detailed",
    "namingConvention": "camelCase",
    "includeValidation": true,
    "performanceOptimization": true
  },
  "textureParameters": {
    "defaultSampler": "TextureSampler",
    "requireExplicitSampler": true,
    "useTextureObject": false
  },
  "outputOptions": {
    "addUsageComments": true,
    "includeNodeGraph": false,
    "generateMaterialFunction": false,
    "addInputDescriptions": true,
    "addPerformanceNotes": false
  },
  "conversionRules": {
    "convertVecToFloat": true,
    "convertMixToLerp": true,
    "convertFractToFrac": true,
    "convertMatToFloatMatrix": true,
    "handleShadertoyUniforms": true,
    "handleFragCoord": true,
    "handleITime": true,
    "handleIResolution": true
  },
  "functionMapping": {
    "customMappings": {
      "myCustomFunction": "MyUECustomFunction"
    }
  },
  "validation": {
    "checkDivisionByZero": true,
    "checkRangeValidity": true,
    "checkTextureBounds": true,
    "warnAboutExpensiveOperations": true
  }
}
